# Job operational runtime logs (exclude bulky log outputs from git tracking while keeping folder)
logs/*.log
logs/*.json
logs/*.txt

# Ensure log folder itself is tracked
!logs/.gitkeep
.superpowers/

# gcluster render / blueprint compose output
lab/build/
